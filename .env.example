# ============================================================
# Santa Rita Diesel — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o arquivo .env no repositório.
# ============================================================

# --- App ---
APP_NAME=santa-rita-diesel
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=1
BACKEND_RELOAD=true

# --- Database ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=santa_rita_diesel
POSTGRES_USER=srd_app
POSTGRES_PASSWORD=srd_dev_password_2026
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# --- MinIO (Storage S3-compatible) ---
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=srd_minio_admin
MINIO_ROOT_PASSWORD=srd_minio_password_2026
MINIO_BUCKET=santa-rita-diesel
MINIO_ENDPOINT=http://${MINIO_HOST}:${MINIO_PORT}

# --- JWT / Auth ---
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING_IN_PRODUCTION
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000/api/v1
